{
  "name": "openbrain-service",
  "version": "0.1.0",
  "private": true,
  "description": "Open Brain memory service (Postgres + pgvector + REST + MCP)",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test src/tests/chatgpt_importer.test.ts src/tests/grok_importer.test.ts src/tests/whatsapp_importer.test.ts src/tests/codexclaw_importer.test.ts src/tests/timestamp_normalization.test.ts src/tests/scripts_common.test.ts src/tests/privacy.test.ts src/tests/semantic_text.test.ts src/tests/query_time.test.ts src/tests/finance_intent.test.ts src/tests/domain_inference.test.ts src/tests/network_graph.test.ts",
    "check": "npm run typecheck && npm test",
    "start": "node dist/server.js",
    "import:chatgpt": "tsx src/scripts/import_chatgpt.ts",
    "import:grok": "tsx src/scripts/import_grok.ts",
    "import:whatsapp": "tsx src/scripts/import_whatsapp.ts",
    "import:codexclaw": "tsx src/scripts/import_codexclaw.ts",
    "metadata:reextract": "tsx src/scripts/reextract_metadata.ts",
    "metadata:refresh:canonical": "tsx src/scripts/refresh_corpus_semantics.ts",
    "metadata:queue:fill": "tsx src/scripts/metadata_queue_fill.ts",
    "metadata:queue:worker": "tsx src/scripts/metadata_queue_worker.ts",
    "metadata:queue:progress": "tsx src/scripts/metadata_queue_progress.ts",
    "dq:audit": "tsx src/scripts/dq_audit.ts",
    "dq:repair": "tsx src/scripts/dq_repair_full.ts",
    "reembed:all": "tsx src/scripts/reembed_all.ts",
    "sanity:dates": "tsx src/scripts/sanity_check_dates.ts",
    "emoji:catalog": "tsx src/scripts/generate_emoji_catalog.ts",
    "v2:bench:generate": "tsx src/scripts/v2_bench_generate.ts",
    "v2:bench:run": "tsx src/scripts/v2_bench_run.ts",
    "v2:bench:signal": "tsx src/scripts/v2_bench_signal.ts",
    "v2:quality:bootstrap": "tsx src/scripts/v2_quality_bootstrap.ts",
    "v2:actors:review": "tsx src/scripts/v2_actor_review_export.ts",
    "v2:actors:apply": "tsx src/scripts/v2_actor_review_apply.ts",
    "v2:actors:merge-prefix-noise": "tsx src/scripts/v2_actor_prefix_noise_merge.ts",
    "v2:actors:pronouns": "tsx src/scripts/v2_actor_pronouns_backfill.ts",
    "v2:actors:pronouns:review": "tsx src/scripts/v2_actor_pronoun_review_export.ts",
    "v2:actors:pronouns:apply": "tsx src/scripts/v2_actor_pronoun_review_apply.ts",
    "v2:network:backfill": "tsx src/scripts/v2_network_backfill.ts",
    "v2:strategy:start": "tsx src/scripts/v2_strategy_start.ts",
    "v2:strategy:step": "tsx src/scripts/v2_strategy_step.ts",
    "v2:strategy:loop": "tsx src/scripts/v2_strategy_loop.ts",
    "v2:strategy:report": "tsx src/scripts/v2_strategy_report.ts",
    "v2:strategy:sms-watch": "tsx src/scripts/v2_strategy_sms_watch.ts",
    "v2:calibration": "tsx src/scripts/v2_calibration.ts",
    "v2:experiment:reset-reseed": "tsx src/scripts/v2_experiment_reset_reseed.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.22.0",
    "@node-rs/argon2": "^2.0.2",
    "adm-zip": "^0.5.16",
    "better-sqlite3": "^11.8.1",
    "dotenv": "^16.5.0",
    "emojibase-data": "^17.0.0",
    "express": "^5.1.0",
    "pg": "^8.16.3",
    "twilio": "^5.13.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.4",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.15.6",
    "tsx": "^4.19.4",
    "typescript": "^5.8.2"
  }
}
