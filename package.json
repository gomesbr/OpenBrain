{
  "name": "openbrain-service",
  "version": "0.1.0",
  "private": true,
  "description": "Open Brain memory service (Postgres + pgvector + REST + MCP)",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test src/tests/chatgpt_importer.test.ts src/tests/grok_importer.test.ts src/tests/whatsapp_importer.test.ts src/tests/codexclaw_importer.test.ts src/tests/timestamp_normalization.test.ts src/tests/scripts_common.test.ts src/tests/privacy.test.ts",
    "check": "npm run typecheck && npm test",
    "start": "node dist/server.js",
    "import:chatgpt": "tsx src/scripts/import_chatgpt.ts",
    "import:grok": "tsx src/scripts/import_grok.ts",
    "import:whatsapp": "tsx src/scripts/import_whatsapp.ts",
    "import:codexclaw": "tsx src/scripts/import_codexclaw.ts",
    "reembed:all": "tsx src/scripts/reembed_all.ts",
    "sanity:dates": "tsx src/scripts/sanity_check_dates.ts"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "@modelcontextprotocol/sdk": "^1.22.0",
    "adm-zip": "^0.5.16",
    "better-sqlite3": "^11.8.1",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "pg": "^8.16.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.4",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.15.6",
    "tsx": "^4.19.4",
    "typescript": "^5.8.2"
  }
}
